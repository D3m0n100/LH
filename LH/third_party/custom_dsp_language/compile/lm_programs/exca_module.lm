PROGRAM EXCAModule
(*
  ================================================================
  EXCA专用模块（已修复）
  ================================================================
  
  功能：工程机械（挖掘机等）专用控制功能
  
  使用功能块：
    - _EXCAKeyParamt: 关键参数管理
    - _EXCAModifyParamt: 参数修改
    - _EXCAOperComp: 操作补偿
    - _EXCASpdUnify: 速度统一
    - _EXCATMaintain: 定时维护
  
  修复内容：
    - 所有 if_condition() 改为 IF...THEN...END_IF
    - 所有 switch_selector() 改为 CASE...OF...END_CASE
    - 完善工程机械控制逻辑
  
  ================================================================
*)

VAR
    (* 系统基础 *)
    system : _System;
    
    (* ============================================
       EXCA功能块
       ============================================ *)
    keyParam : _EXCAKeyParamt;
    modifyParam : _EXCAModifyParamt;
    operComp : _EXCAOperComp;
    spdUnify : _EXCASpdUnify;
    tMaintain : _EXCATMaintain;
    
    (* ============================================
       关键参数
       ============================================ *)
    engineSpeed : INT;
    hydraulicPressure : INT;
    oilTemp : INT;
    fuelLevel : INT;
    batteryVoltage : INT;
    
    (* ============================================
       操作参数
       ============================================ *)
    armSpeed : INT;
    boomSpeed : INT;
    bucketSpeed : INT;
    rotationSpeed : INT;
    travelSpeed : INT;
    
    (* ============================================
       补偿参数
       ============================================ *)
    loadCompensation : INT;
    tempCompensation : INT;
    wearCompensation : INT;
    altitudeCompensation : INT;
    
    (* ============================================
       速度控制
       ============================================ *)
    targetSpeed : INT;
    actualSpeed : INT;
    speedRatio : INT;
    speedMode : INT;
    
    (* ============================================
       维护参数
       ============================================ *)
    workingHours : INT;
    nextMaintHours : INT;
    maintInterval : INT;
    lastMaintHours : INT;
    maintAlert : BOOL;
    maintDue : BOOL;
    
    (* ============================================
       系统状态
       ============================================ *)
    engineRunning : BOOL;
    hydraulicReady : BOOL;
    systemNormal : BOOL;
    systemError : BOOL;
    
    (* ============================================
       工作模式
       ============================================ *)
    workMode : INT;
    powerOutput : INT;
    fuelEconomy : BOOL;
    
    (* 模式定义 *)
    MODE_IDLE : INT := 0;
    MODE_STANDARD : INT := 1;
    MODE_ECONOMY : INT := 2;
    MODE_POWER : INT := 3;
END_VAR

(* ================================================================
   系统初始化
   ================================================================ *)
system(Author := 1, Config := 100, Date := 2601);

(* ============================================
   初始化变量
   ============================================ *)
engineRunning := FALSE;
hydraulicReady := FALSE;
systemNormal := TRUE;
systemError := FALSE;

workMode := MODE_STANDARD;
powerOutput := 100;
fuelEconomy := FALSE;

maintAlert := FALSE;
maintDue := FALSE;

(* ================================================================
   EXCA关键参数管理
   ================================================================ *)
(*
   监控和管理工程机械的关键运行参数
   包括发动机、液压、温度、燃油等
*)

engineSpeed := 1800;
hydraulicPressure := 280;
oilTemp := 65;
fuelLevel := 75;
batteryVoltage := 24;

keyParam(
    EngineSpeed := 1800,
    HydraulicPress := 280,
    OilTemp := 65,
    FuelLevel := 75,
    ParamCount := 10
);

(* 关键参数检查 *)
IF engineSpeed > 0 AND engineSpeed < 2500 THEN
    engineRunning := TRUE;
ELSE
    engineRunning := FALSE;
END_IF;

IF hydraulicPressure > 200 AND hydraulicPressure < 350 THEN
    hydraulicReady := TRUE;
ELSE
    hydraulicReady := FALSE;
END_IF;

(* 温度监控 *)
IF oilTemp > 90 THEN
    (* 温度过高，降低功率 *)
    powerOutput := 80;
    systemError := TRUE;
ELSIF oilTemp > 80 THEN
    (* 温度偏高，警告 *)
    powerOutput := 90;
ELSE
    (* 温度正常 *)
    IF workMode = MODE_POWER THEN
        powerOutput := 120;
    ELSE
        powerOutput := 100;
    END_IF;
END_IF;

(* 燃油检查 *)
IF fuelLevel < 10 THEN
    (* 燃油低，强制省油模式 *)
    workMode := MODE_ECONOMY;
    fuelEconomy := TRUE;
ELSIF fuelLevel < 25 THEN
    (* 燃油偏低，警告 *)
    maintAlert := TRUE;
END_IF;

(* ================================================================
   EXCA参数修改
   ================================================================ *)
(*
   允许在线调整工作参数
   需要密码保护
*)

modifyParam(
    ParamID := 1,
    NewValue := 2000,
    Enable := 0,
    PasswordOK := 0
);

(* ================================================================
   EXCA操作补偿
   ================================================================ *)
(*
   根据负载、温度等条件自动补偿操作响应
*)

loadCompensation := 100;
tempCompensation := 95;
wearCompensation := 98;
altitudeCompensation := 100;

(* 根据油温调整补偿 *)
IF oilTemp < 20 THEN
    tempCompensation := 80;  (* 油温低，动作慢 *)
ELSIF oilTemp < 40 THEN
    tempCompensation := 90;
ELSIF oilTemp > 80 THEN
    tempCompensation := 95;  (* 油温高，略降速 *)
ELSE
    tempCompensation := 100; (* 温度适中，全速 *)
END_IF;

operComp(
    LoadFactor := loadCompensation,
    TempFactor := tempCompensation,
    WearFactor := wearCompensation,
    Enable := 1
);

(* 应用补偿后的操作速度 *)
armSpeed := (100 * tempCompensation) / 100;
boomSpeed := (100 * tempCompensation) / 100;
bucketSpeed := (100 * tempCompensation) / 100;
rotationSpeed := (100 * tempCompensation) / 100;

(* ================================================================
   EXCA速度统一
   ================================================================ *)
(*
   统一管理各执行机构的速度控制
*)

targetSpeed := 100;
actualSpeed := 0;
speedRatio := 100;
speedMode := 1;

spdUnify(
    TargetSpeed := 100,
    ActualSpeed := actualSpeed,
    SpeedRatio := 100,
    Enable := 1,
    Mode := speedMode
);

(* 根据工作模式调整速度 *)
CASE workMode OF
    0:
        (* 怠速模式 *)
        targetSpeed := 20;
        armSpeed := 20;
        boomSpeed := 20;
        bucketSpeed := 20;
        rotationSpeed := 10;
    
    1:
        (* 标准模式 *)
        targetSpeed := 100;
        armSpeed := 100;
        boomSpeed := 100;
        bucketSpeed := 100;
        rotationSpeed := 50;
    
    2:
        (* 省油模式 *)
        targetSpeed := 80;
        armSpeed := 80;
        boomSpeed := 80;
        bucketSpeed := 80;
        rotationSpeed := 40;
    
    3:
        (* 强力模式 *)
        targetSpeed := 120;
        armSpeed := 120;
        boomSpeed := 120;
        bucketSpeed := 120;
        rotationSpeed := 60;

ELSE
    (* 默认标准模式 *)
    targetSpeed := 100;
END_CASE;

(* ================================================================
   EXCA定时维护
   ================================================================ *)
(*
   根据工作时间提醒维护保养
*)

workingHours := 1250;
maintInterval := 250;
lastMaintHours := 1000;
nextMaintHours := lastMaintHours + maintInterval;

tMaintain(
    WorkingHours := workingHours,
    MaintInterval := maintInterval,
    LastMaintHours := lastMaintHours,
    Enable := 1
);

(* 检查是否需要维护 *)
IF workingHours >= nextMaintHours THEN
    maintDue := TRUE;
    maintAlert := TRUE;
ELSIF workingHours >= (nextMaintHours - 50) THEN
    (* 即将到维护期，提前50小时提醒 *)
    maintAlert := TRUE;
    maintDue := FALSE;
ELSE
    maintAlert := FALSE;
    maintDue := FALSE;
END_IF;

(* ================================================================
   系统状态监控
   ================================================================ *)

(* 发动机状态检查 *)
IF engineSpeed > 600 AND engineSpeed < 2500 THEN
    engineRunning := TRUE;
ELSE
    engineRunning := FALSE;
    systemError := TRUE;
END_IF;

(* 液压系统状态检查 *)
IF hydraulicPressure > 200 AND hydraulicPressure < 350 THEN
    hydraulicReady := TRUE;
ELSE
    hydraulicReady := FALSE;
    systemError := TRUE;
END_IF;

(* 整体系统状态 *)
IF engineRunning AND hydraulicReady AND (NOT systemError) THEN
    systemNormal := TRUE;
ELSE
    systemNormal := FALSE;
END_IF;

(* ================================================================
   工作模式切换
   ================================================================ *)
(*
   根据工作模式设置不同的功率输出
*)

CASE workMode OF
    0:
        (* 怠速模式 - 最小功率 *)
        powerOutput := 40;
        fuelEconomy := TRUE;
    
    1:
        (* 标准作业模式 - 平衡性能和燃油效率 *)
        powerOutput := 100;
        fuelEconomy := FALSE;
    
    2:
        (* 省油模式 - 降低功率，延长工作时间 *)
        powerOutput := 80;
        fuelEconomy := TRUE;
    
    3:
        (* 强力模式 - 最大功率，适用于重载作业 *)
        powerOutput := 120;
        fuelEconomy := FALSE;

ELSE
    (* 默认标准模式 *)
    powerOutput := 100;
    fuelEconomy := FALSE;
END_CASE;

(* 根据功率输出调整各机构速度 *)
armSpeed := (100 * powerOutput) / 100;
boomSpeed := (100 * powerOutput) / 100;
bucketSpeed := (100 * powerOutput) / 100;
rotationSpeed := (50 * powerOutput) / 100;

(* ================================================================
   故障保护
   ================================================================ *)

(* 温度保护 *)
IF oilTemp > 100 THEN
    (* 温度过高，强制停机 *)
    engineRunning := FALSE;
    hydraulicReady := FALSE;
    systemError := TRUE;
    workMode := MODE_IDLE;
END_IF;

(* 压力保护 *)
IF hydraulicPressure > 350 THEN
    (* 压力过高，泄压 *)
    hydraulicReady := FALSE;
    systemError := TRUE;
END_IF;

(* 燃油保护 *)
IF fuelLevel < 5 THEN
    (* 燃油极低，停机 *)
    engineRunning := FALSE;
    systemError := TRUE;
END_IF;

(* ================================================================
   性能优化
   ================================================================ *)

(* 根据实际负载动态调整 *)
IF actualSpeed < (targetSpeed / 2) THEN
    (* 实际速度远低于目标，可能负载过大 *)
    loadCompensation := 120;  (* 增加补偿 *)
ELSIF actualSpeed > (targetSpeed * 11 / 10) THEN
    (* 实际速度超过目标，可能负载过小 *)
    loadCompensation := 90;   (* 降低补偿 *)
ELSE
    (* 速度正常 *)
    loadCompensation := 100;
END_IF;

END_PROGRAM
