PROGRAM Main
(*
  ================================================================
  LM工业控制系统 - 主程序（已修复）
  ================================================================
  
  版本：v1.1 - 格式修复版
  作者：LM Compiler Project
  日期：2026-02-10
  
  功能：通用工业控制系统
  
  模块组成：
    1. main.lm           - 主程序及状态机
    2. io_module.lm      - I/O驱动
    3. control_module.lm - 控制逻辑
    4. comm_module.lm    - 通信模块
    5. display_module.lm - 显示交互
    6. exca_module.lm    - EXCA专用
  
  修复内容：
    - 所有 if_condition() 改为标准 IF...THEN...END_IF
    - 完善状态机转换逻辑
    - 修正变量类型和初始化
  
  ================================================================
*)

VAR
    (* ============================================
       系统核心变量
       ============================================ *)
    system : _System;
    
    (* 系统状态 *)
    systemRunning : BOOL;
    systemInitialized : BOOL;
    systemError : BOOL;
    
    (* 周期计数器 *)
    mainCycleCounter : INT;
    scanCycleTime : INT;
    
    (* ============================================
       I/O数据
       ============================================ *)
    (* 模拟量输入 *)
    ai_pressure : REAL;
    ai_temperature : REAL;
    ai_flow : REAL;
    ai_level : REAL;
    
    (* 数字量输入 *)
    di_startButton : BOOL;
    di_stopButton : BOOL;
    di_emergencyStop : BOOL;
    
    (* 数字量输出 *)
    do_motorRun : BOOL;
    do_valveOpen : BOOL;
    do_alarmLED : BOOL;
    
    (* ============================================
       过程变量
       ============================================ *)
    processSetpoint : REAL;
    processValue : REAL;
    processOutput : REAL;
    
    (* ============================================
       控制参数
       ============================================ *)
    controlMode : INT;
    targetValue : REAL;
    actualValue : REAL;
    errorValue : REAL;
    
    (* ============================================
       状态机
       ============================================ *)
    currentState : INT;
    nextState : INT;
    stateTimer : INT;
    
    (* 状态定义 *)
    STATE_INIT : INT := 0;
    STATE_IDLE : INT := 1;
    STATE_RUNNING : INT := 2;
    STATE_STOPPING : INT := 3;
    STATE_ERROR : INT := 4;
    STATE_MAINTENANCE : INT := 5;
    
    (* ============================================
       通信数据
       ============================================ *)
    commConnected : BOOL;
    commTxCount : INT;
    commRxCount : INT;
    commErrorCount : INT;
    
    (* ============================================
       安全监控
       ============================================ *)
    safetyOK : BOOL;
    tempAlarm : BOOL;
    pressureAlarm : BOOL;
    flowAlarm : BOOL;
    
    (* ============================================
       显示数据
       ============================================ *)
    displayPage : INT;
    displayRefresh : BOOL;
    keyPressed : INT;
END_VAR

(* ================================================================
   主程序开始
   ================================================================ *)

(* ============================================
   1. 系统初始化
   ============================================ *)
system(Author := 1, Config := 100, Date := 2601);

(* 初始化系统标志 *)
systemInitialized := FALSE;
systemRunning := FALSE;
systemError := FALSE;

(* 状态初始化 *)
currentState := STATE_INIT;
nextState := STATE_INIT;

(* ============================================
   2. 初始化I/O
   ============================================ *)
ai_pressure := 0.0;
ai_temperature := 0.0;
ai_flow := 0.0;
ai_level := 0.0;

di_startButton := FALSE;
di_stopButton := FALSE;
di_emergencyStop := FALSE;

do_motorRun := FALSE;
do_valveOpen := FALSE;
do_alarmLED := FALSE;

(* ============================================
   3. 初始化控制参数
   ============================================ *)
controlMode := 1;
processSetpoint := 50.0;
processValue := 0.0;
processOutput := 0.0;

targetValue := 100.0;
actualValue := 0.0;
errorValue := 0.0;

(* ============================================
   4. 初始化通信
   ============================================ *)
commConnected := FALSE;
commTxCount := 0;
commRxCount := 0;
commErrorCount := 0;

(* ============================================
   5. 初始化安全监控
   ============================================ *)
safetyOK := TRUE;
tempAlarm := FALSE;
pressureAlarm := FALSE;
flowAlarm := FALSE;

(* ============================================
   6. 初始化显示
   ============================================ *)
displayPage := 0;
displayRefresh := TRUE;
keyPressed := 0;

(* ============================================
   7. 主循环初始化
   ============================================ *)
mainCycleCounter := 0;
scanCycleTime := 10;

(* ============================================
   8. 初始化完成
   ============================================ *)
systemInitialized := TRUE;
currentState := STATE_IDLE;

(* ================================================================
   主循环：状态机执行
   ================================================================ *)

(* ============================================
   状态机主循环
   ============================================ *)
CASE currentState OF
    
    (* ============================================
       STATE 0: INIT - 初始化状态
       ============================================ *)
    0:
        IF systemInitialized THEN
            nextState := STATE_IDLE;
            currentState := STATE_IDLE;
        END_IF;
    
    (* ============================================
       STATE 1: IDLE - 空闲状态
       ============================================ *)
    1:
        systemRunning := FALSE;
        do_motorRun := FALSE;
        do_valveOpen := FALSE;
        
        (* 等待启动命令 *)
        IF di_startButton AND safetyOK THEN
            nextState := STATE_RUNNING;
            currentState := STATE_RUNNING;
        END_IF;
        
        (* 检查故障 *)
        IF NOT safetyOK OR di_emergencyStop THEN
            nextState := STATE_ERROR;
            currentState := STATE_ERROR;
        END_IF;
    
    (* ============================================
       STATE 2: RUNNING - 运行状态
       ============================================ *)
    2:
        systemRunning := TRUE;
        
        (* 模拟读取I/O数据 *)
        ai_pressure := 5.0;
        ai_temperature := 25.0;
        ai_flow := 50.0;
        ai_level := 2.5;
        
        (* 执行控制算法 *)
        processValue := ai_temperature;
        errorValue := processSetpoint - processValue;
        
        (* 根据误差控制输出 *)
        IF errorValue > 5.0 THEN
            do_motorRun := TRUE;
            do_valveOpen := TRUE;
        ELSIF errorValue < -5.0 THEN
            do_motorRun := FALSE;
            do_valveOpen := FALSE;
        END_IF;
        
        (* 检查停止条件 *)
        IF di_stopButton THEN
            nextState := STATE_STOPPING;
            currentState := STATE_STOPPING;
        END_IF;
        
        (* 检查紧急停止 *)
        IF di_emergencyStop OR NOT safetyOK THEN
            nextState := STATE_ERROR;
            currentState := STATE_ERROR;
        END_IF;
        
        (* 检查安全条件 *)
        IF ai_temperature > 80.0 THEN
            tempAlarm := TRUE;
            nextState := STATE_ERROR;
            currentState := STATE_ERROR;
        END_IF;
        
        IF ai_pressure > 10.0 THEN
            pressureAlarm := TRUE;
            nextState := STATE_ERROR;
            currentState := STATE_ERROR;
        END_IF;
    
    (* ============================================
       STATE 3: STOPPING - 停止状态
       ============================================ *)
    3:
        systemRunning := FALSE;
        
        (* 安全停机流程 *)
        do_motorRun := FALSE;
        do_valveOpen := FALSE;
        
        (* 延时后返回空闲 *)
        IF stateTimer > 0 THEN
            stateTimer := stateTimer - 1;
        ELSE
            stateTimer := 100;
            nextState := STATE_IDLE;
            currentState := STATE_IDLE;
        END_IF;
    
    (* ============================================
       STATE 4: ERROR - 故障状态
       ============================================ *)
    4:
        systemError := TRUE;
        systemRunning := FALSE;
        
        (* 关闭所有输出 *)
        do_motorRun := FALSE;
        do_valveOpen := FALSE;
        do_alarmLED := TRUE;
        
        (* 清除故障后可恢复 *)
        IF NOT di_emergencyStop AND safetyOK AND NOT tempAlarm AND NOT pressureAlarm THEN
            IF keyPressed = 1 THEN  (* 需要手动确认 *)
                systemError := FALSE;
                tempAlarm := FALSE;
                pressureAlarm := FALSE;
                do_alarmLED := FALSE;
                nextState := STATE_IDLE;
                currentState := STATE_IDLE;
            END_IF;
        END_IF;
    
    (* ============================================
       STATE 5: MAINTENANCE - 维护状态
       ============================================ *)
    5:
        systemRunning := FALSE;
        do_motorRun := FALSE;
        do_valveOpen := FALSE;
        
        (* 维护模式下允许手动操作 *)
        IF keyPressed = 99 THEN  (* 退出维护模式 *)
            nextState := STATE_IDLE;
            currentState := STATE_IDLE;
        END_IF;

END_CASE;

(* ============================================
   循环计数器递增
   ============================================ *)
mainCycleCounter := mainCycleCounter + 1;
IF mainCycleCounter > 10000 THEN
    mainCycleCounter := 0;
END_IF;

(* ============================================
   安全监控（每个周期都执行）
   ============================================ *)
IF ai_temperature > 80.0 THEN
    tempAlarm := TRUE;
    safetyOK := FALSE;
END_IF;

IF ai_pressure > 10.0 THEN
    pressureAlarm := TRUE;
    safetyOK := FALSE;
END_IF;

IF ai_flow < 10.0 AND systemRunning THEN
    flowAlarm := TRUE;
END_IF;

END_PROGRAM
