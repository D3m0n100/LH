PROGRAM SafetyModule
(*
  安全与监控模块
  功能：越限监视、密码验证、完整性检查、安全功能控制
  使用功能块：5个安全监控相关功能块
*)

VAR
    (* 系统基础 *)
    system : System;
    
    (* ===== 越限监视 ===== *)
    belowWatch : FloatBelowWatch;
    overWatch : FloatOverWatch;
    
    (* ===== 安全验证 ===== *)
    passwordVerify : PasswordVerify2;
    
    (* ===== 安全功能控制 ===== *)
    safetyFC : EXCASFC;
    
    (* ===== 完整性检查 ===== *)
    integrityCheck : EXCAIntCheck;
    
    (* 监控数据 *)
    temperatureValue : REAL;
    pressureValue : REAL;
    flowValue : REAL;
    
    (* 报警标志 *)
    tempBelowAlarm : BOOL;
    tempOverAlarm : BOOL;
    pressureOverAlarm : BOOL;
    flowBelowAlarm : BOOL;
    
    (* 安全状态 *)
    passwordValid : BOOL;
    safetyOK : BOOL;
    integrityOK : BOOL;
    systemSafe : BOOL;
    
    (* 用户输入 *)
    inputPassword : INT;
    correctPassword : INT;
    
    (* 检查计数 *)
    checkCounter : INT;
END_VAR

(* ============================================
   系统初始化
   ============================================ *)
system(Author := 1, Config := 100, Date := 2601);

(* ============================================
   温度监控
   正常范围：10°C ~ 80°C
   ============================================ *)
temperatureValue := 25.0;

(* 温度下限监视 - 低于10°C报警 *)
belowWatch(Input := 25, LowLimit := 10, Hysteresis := 2, Enable := 1);
tempBelowAlarm := FALSE;

(* 温度上限监视 - 高于80°C报警 *)
overWatch(Input := 25, HighLimit := 80, Hysteresis := 2, Enable := 1);
tempOverAlarm := FALSE;

(* ============================================
   压力监控
   正常范围：0 ~ 10bar
   ============================================ *)
pressureValue := 5.0;

(* 压力上限监视 - 高于10bar报警 *)
overWatch(Input := 5, HighLimit := 10, Hysteresis := 0, Enable := 1);
pressureOverAlarm := FALSE;

(* ============================================
   流量监控
   正常范围：> 5 L/min
   ============================================ *)
flowValue := 50.0;

(* 流量下限监视 - 低于5L/min报警 *)
belowWatch(Input := 50, LowLimit := 5, Hysteresis := 1, Enable := 1);
flowBelowAlarm := FALSE;

(* ============================================
   密码验证系统
   用于操作权限控制
   ============================================ *)
correctPassword := 1234;
inputPassword := 0;

(* 密码验证 - 三次机会 *)
passwordVerify(InputPassword := 0, CorrectPassword := 1234, MaxAttempts := 3, Reset := 0);
passwordValid := FALSE;

(* ============================================
   安全功能控制 (Safety Function Control)
   用于关键安全功能的管理
   ============================================ *)
safetyFC(Enable := 1, EmergencyStop := 0, SafetyInput1 := 1, SafetyInput2 := 1);
safetyOK := TRUE;

(* ============================================
   完整性检查 (Integrity Check)
   检查系统数据和配置的完整性
   ============================================ *)
integrityCheck(CheckEnable := 1, DataCRC := 12345, ConfigValid := 1);
integrityOK := TRUE;
checkCounter := 0;

(* ============================================
   综合安全状态评估
   ============================================ *)
systemSafe := TRUE;

(* 如果有任何报警，设置系统不安全状态 *)
IF tempBelowAlarm OR tempOverAlarm OR pressureOverAlarm OR flowBelowAlarm THEN
    systemSafe := FALSE;
END_IF;

(* 检查温度报警 *)
IF tempBelowAlarm OR tempOverAlarm THEN
    systemSafe := FALSE;
ELSE
    systemSafe := TRUE;
END_IF;

(* 检查压力报警 *)
IF pressureOverAlarm THEN
    systemSafe := FALSE;
END_IF;

(* 检查流量报警 *)
IF flowBelowAlarm THEN
    systemSafe := FALSE;
END_IF;

(* 检查密码状态 *)
IF passwordValid THEN
    systemSafe := TRUE;
END_IF;

(* 检查安全功能 *)
IF safetyOK THEN
    systemSafe := TRUE;
END_IF;

(* 检查完整性 *)
IF integrityOK THEN
    systemSafe := TRUE;
END_IF;

END_PROGRAM
