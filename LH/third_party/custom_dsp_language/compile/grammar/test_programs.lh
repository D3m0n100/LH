// ============================================================================
// LH Language Test Programs
// ============================================================================
// Purpose: Test various aspects of the grammar
// ============================================================================

// ----------------------------------------------------------------------------
// Test 1: Minimal Program (should parse successfully)
// ----------------------------------------------------------------------------
PROGRAM MinimalTest
VAR
    system : System;
END_VAR

system(Author := 1, Config := 100, Date := 2601);

END_PROGRAM

// ----------------------------------------------------------------------------
// Test 2: Multiple Variables
// ----------------------------------------------------------------------------
PROGRAM VariableTest
VAR
    system : System;
    counter : INT;
    temperature : REAL;
    is_active : BOOL;
    message : STRING;
END_VAR

system(Author := 1, Config := 100, Date := 2601);

counter := 0;
temperature := 25.5;
is_active := TRUE;
message := 'Hello LH';

END_PROGRAM

// ----------------------------------------------------------------------------
// Test 3: Arithmetic Expressions
// ----------------------------------------------------------------------------
PROGRAM ArithmeticTest
VAR
    a : REAL;
    b : REAL;
    c : REAL;
    result : REAL;
END_VAR

a := 10.0;
b := 20.0;
c := 5.0;

result := a + b;
result := a - b;
result := a * b;
result := a / b;
result := (a + b) * c;
result := a + b * c;  // Test precedence

END_PROGRAM

// ----------------------------------------------------------------------------
// Test 4: Comparison and Logical
// ----------------------------------------------------------------------------
PROGRAM ComparisonTest
VAR
    temp : REAL;
    is_hot : BOOL;
    is_cold : BOOL;
    is_normal : BOOL;
    alarm : BOOL;
END_VAR

temp := 25.0;

is_hot := temp > 30.0;
is_cold := temp < 10.0;
is_normal := (temp >= 15.0) AND (temp <= 28.0);

alarm := is_hot OR is_cold;
alarm := NOT is_normal;

END_PROGRAM

// ----------------------------------------------------------------------------
// Test 5: Function Block with Multiple Parameters
// ----------------------------------------------------------------------------
PROGRAM FunctionBlockTest
VAR
    system : System;
    pid : PID;
    setpoint : REAL;
    process_value : REAL;
END_VAR

system(Author := 1, Config := 100, Date := 2601);

setpoint := 50.0;
process_value := 45.0;

pid(
    SetPoint := setpoint,
    ProcessValue := process_value,
    Kp := 1.5,
    Ki := 0.1,
    Kd := 0.05
);

END_PROGRAM

// ----------------------------------------------------------------------------
// Test 6: Comments Test
// ----------------------------------------------------------------------------
PROGRAM CommentTest
VAR
    // This is a single-line comment
    system : System;  // Inline comment
    
    (*
      This is a
      multi-line comment
    *)
    value : REAL;
END_VAR

// System initialization
system(Author := 1, Config := 100, Date := 2601);

(* Calculate something *)
value := 42.0;  // The answer

END_PROGRAM

// ----------------------------------------------------------------------------
// Test 7: Empty Statements
// ----------------------------------------------------------------------------
PROGRAM EmptyStatementTest
VAR
    system : System;
END_VAR

system(Author := 1, Config := 100, Date := 2601);
;  // Empty statement
;  // Another empty statement

END_PROGRAM

// ----------------------------------------------------------------------------
// Test 8: Complex Expressions
// ----------------------------------------------------------------------------
PROGRAM ComplexExpressionTest
VAR
    x : REAL;
    y : REAL;
    z : REAL;
    result : REAL;
    condition : BOOL;
END_VAR

x := 10.0;
y := 5.0;
z := 2.0;

result := x * y + z;
result := x * (y + z);
result := (x + y) / (z - 1.0);

condition := (x > y) AND (y > z);
condition := (x = 10.0) OR (y <> 5.0);
condition := NOT (x < 0.0);

END_PROGRAM

